{
  "name": "@agent_design/shared",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/esm/constants/index.js",
      "require": "./dist/constants/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/types/index.js",
      "require": "./dist/types/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/esm/schemas/index.js",
      "require": "./dist/schemas/index.js"
    }
  },
  "scripts": {
    "build:types": "tsc",
    "build:js": "tsup src/index.ts src/constants/index.ts src/types/index.ts src/schemas/index.ts --format esm,cjs --out-dir dist --legacy-output --dts",
    "build": "pnpm run build:types && pnpm run build:js"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.5"
  }
}